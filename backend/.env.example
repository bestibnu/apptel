# --- Server ---
PORT=3000
# Public base URL of THIS backend (e.g. your ngrok https URL). Used for Twilio status callbacks.
PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.dev

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Twilio: account ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Twilio: API Key (Console > Account > API keys & tokens) ---
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_twilio_api_secret

# --- Twilio: TwiML App (Console > Voice > TwiML > TwiML Apps) ---
# Set its Voice Request URL to:  $PUBLIC_BASE_URL/voice/twiml
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Twilio: Verify service (Console > Verify > Services) ---
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Twilio: the phone number used as outbound caller ID (E.164, e.g. +12025550123) ---
TWILIO_CALLER_ID=+10000000000

# --- Wallet ---
# Credit (in cents) granted to a brand-new user on first signup.
SEED_CREDIT_CENTS=500

# --- Abuse / fraud guard ---
# Hard cap on a single call's billable length, in seconds (default 3600 = 60 min).
MAX_CALL_SECONDS=3600
